{
  "$schema": "./orchestration.schema.json",
  "library": {
    "name": "@myorg/components",
    "path": "../component-library",
    "buildCommand": "npm run build",
    "testCommand": "npm test",
    "lintCommand": "npm run lint",
    "publishCommand": "node ../agent-orchestration/scripts/verdaccio-publish.mjs",
    "packageManager": "npm"
  },
  "consumers": [
    {
      "name": "app-one",
      "path": "../app-one",
      "packageManager": "npm",
      "installCommand": "npm install",
      "buildCommand": "npm run build",
      "testCommand": "npm test",
      "lintCommand": "npm run lint",
      "dependencyName": "@myorg/components"
    },
    {
      "name": "app-two",
      "path": "../app-two",
      "packageManager": "pnpm",
      "installCommand": "pnpm install",
      "buildCommand": "pnpm run build",
      "testCommand": "pnpm test",
      "lintCommand": "pnpm run lint",
      "dependencyName": "@myorg/components"
    }
  ],
  "verdaccio": {
    "port": 4873,
    "storage": "/tmp/verdaccio-storage",
    "url": "http://localhost:4873"
  },
  "orchestration": {
    "maxIterations": 5,
    "verifySteps": ["build", "test", "lint"],
    "allowConsumerFixes": true
  }
}
